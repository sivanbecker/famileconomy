legacy-peer-deps=true

# Audit level set to HIGH to ignore moderate CVEs in development dependencies.
# Pre-existing moderate CVEs in Expo 51, vitest, and Next.js development tooling
# cannot be resolved without major breaking upgrades (Expo 55+, Next.js 17+, vitest 4.x).
# These are development-only, never shipped to production.
# Trivy performs the actual security gate (HIGH/CRITICAL vulns only).
# See .trivyignore for documentation of Expo SDK 51 CVEs.
audit-level=high
