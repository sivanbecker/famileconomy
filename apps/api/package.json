{
  "name": "@famileconomy/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "db:migrate": "node-pg-migrate up --migrations-dir migrations",
    "db:migrate:check": "node-pg-migrate status --migrations-dir migrations",
    "db:migrate:status": "node-pg-migrate status --migrations-dir migrations",
    "db:migrate:create": "node-pg-migrate create --migrations-dir migrations",
    "db:generate-types": "prisma generate",
    "dev:instrument": "tsx --import ./src/instrumentation.ts src/server.ts"
  },
  "dependencies": {
    "@famileconomy/types": "*",
    "@famileconomy/utils": "*",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^12.0.1",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@logtail/pino": "^0.5.8",
    "@opentelemetry/api": "^1.8.0",
    "@opentelemetry/auto-instrumentations-node": "^0.48.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.51.0",
    "@opentelemetry/sdk-node": "^0.217.0",
    "@opentelemetry/semantic-conventions": "1.40.0",
    "@prisma/client": "^5.12.0",
    "@sentry/node": "^8.55.1",
    "argon2": "^0.40.0",
    "bullmq": "^5.7.0",
    "fastify": "^5.8.0",
    "googleapis": "^171.4.0",
    "ioredis": "^5.3.0",
    "jsonwebtoken": "^9.0.0",
    "node-pg-migrate": "^8.0.0",
    "pg": "^8.11.0",
    "pino": "^9.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^20.12.0",
    "@types/pg": "^8.11.0",
    "@typescript-eslint/eslint-plugin": "^7.6.0",
    "@typescript-eslint/parser": "^7.6.0",
    "@vitest/coverage-v8": "^1.4.0",
    "eslint": "^9.0.0",
    "eslint-plugin-security": "^3.0.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^5.12.0",
    "prisma-generator-typescript-interfaces": "^3.1.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}
