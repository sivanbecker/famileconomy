generator client {
  provider = "prisma-client-js"
}

generator typescriptInterfaces {
  provider = "prisma-generator-typescript-interfaces"
  output   = "../../../packages/types/src/database.ts"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users & Auth ────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  locale       String   @default("he")
  googleRefreshToken Bytes? @map("google_refresh_token")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  accounts       Account[]
  refreshTokens  RefreshToken[]
  auditLogs      AuditLog[]

  @@map("users")
}

model RefreshToken {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  tokenHash  String    @unique @map("token_hash")
  familyId   String    @map("family_id")
  usedAt     DateTime? @map("used_at")
  expiresAt  DateTime  @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ─── Accounts ────────────────────────────────────────────────────────────────

model Account {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  name      Bytes
  type      AccountType
  currency  String   @default("ILS")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@map("accounts")
}

enum AccountType {
  CHECKING
  SAVINGS
  CREDIT_CARD
  CASH

  @@map("account_type")
}

enum TransactionStatus {
  CLEARED
  PENDING
  DUPLICATE
  REVIEWED_OK

  @@map("transaction_status")
}

// ─── Transactions ─────────────────────────────────────────────────────────────
// Monetary columns are BYTEA in PostgreSQL (pgcrypto encrypted).
// Prisma maps them as Bytes. The service layer decrypts to Int (agorot).

model Transaction {
  id              String            @id @default(uuid())
  accountId       String            @map("account_id")
  importBatchId   String?           @map("import_batch_id")

  // Purchase date (always present); charge/billing date when provided by the bank
  transactionDate DateTime          @db.Date @map("transaction_date")
  chargeDate      DateTime?         @db.Date @map("charge_date")

  // Encrypted: merchant name
  description     Bytes

  // Encrypted: charge amount in agorot (positive = debit, negative = credit/cancellation)
  amountAgorot    Bytes             @map("amount_agorot")

  // Encrypted: original amount when transaction currency differs from ILS
  originalAmountAgorot Bytes?       @map("original_amount_agorot")
  originalCurrency     String?      @map("original_currency")

  category        String?
  cardLastFour    String?           @map("card_last_four")
  status          TransactionStatus @default(CLEARED)
  dedupeHash      String?           @map("dedupe_hash")
  installmentNum  Int?              @map("installment_num")
  installmentOf   Int?              @map("installment_of")
  duplicateOf     String?           @map("duplicate_of")
  createdAt       DateTime          @default(now()) @map("created_at")

  account            Account        @relation(fields: [accountId], references: [id], onDelete: Cascade)
  importBatch        ImportBatch?   @relation(fields: [importBatchId], references: [id])
  recurringMatch     RecurringMatch?
  originalTransaction Transaction?  @relation("DuplicateOf", fields: [duplicateOf], references: [id], onDelete: SetNull)
  duplicates         Transaction[]  @relation("DuplicateOf")

  @@map("transactions")
}

model ImportBatch {
  id          String   @id @default(uuid())
  accountId   String   @map("account_id")
  filename    String
  fileHash    String?  @map("file_hash")
  rowCount    Int      @map("row_count")
  importedAt  DateTime @default(now()) @map("imported_at")

  transactions Transaction[]

  @@unique([accountId, fileHash])
  @@map("import_batches")
}

// ─── Recurring ────────────────────────────────────────────────────────────────

model RecurringExpense {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  name            String
  expectedAmountAgorot Bytes @map("expected_amount_agorot")
  dayOfMonth      Int?     @map("day_of_month")
  matchPattern    String   @map("match_pattern")
  active          Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  matches RecurringMatch[]

  @@map("recurring_expenses")
}

model RecurringMatch {
  id                 String   @id @default(uuid())
  recurringExpenseId String   @map("recurring_expense_id")
  transactionId      String   @unique @map("transaction_id")
  month              Int
  year               Int
  matchedAt          DateTime @default(now()) @map("matched_at")

  recurringExpense RecurringExpense @relation(fields: [recurringExpenseId], references: [id], onDelete: Cascade)
  transaction      Transaction      @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@map("recurring_matches")
}

// ─── Audit Log ────────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  action     String
  tableName  String   @map("table_name")
  recordId   String   @map("record_id")
  oldValues  Json?    @map("old_values")
  newValues  Json?    @map("new_values")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("audit_log")
}
