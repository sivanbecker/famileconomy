generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users & Auth ────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  locale       String   @default("he")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  accounts       Account[]
  refreshTokens  RefreshToken[]
  auditLogs      AuditLog[]

  @@map("users")
}

model RefreshToken {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  tokenHash  String    @unique @map("token_hash")
  familyId   String    @map("family_id")
  usedAt     DateTime? @map("used_at")
  expiresAt  DateTime  @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ─── Accounts ────────────────────────────────────────────────────────────────

model Account {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  name      String
  type      AccountType
  currency  String   @default("ILS")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@map("accounts")
}

enum AccountType {
  CHECKING
  SAVINGS
  CREDIT_CARD
  CASH

  @@map("account_type")
}

// ─── Transactions ─────────────────────────────────────────────────────────────

model Transaction {
  id              String   @id @default(uuid())
  accountId       String   @map("account_id")
  importBatchId   String?  @map("import_batch_id")
  date            DateTime @db.Date
  description     String
  amountShekels   Int      @map("amount_shekels")
  category        String?
  dedupeHash      String?  @unique @map("dedupe_hash")
  installmentNum  Int?     @map("installment_num")
  installmentOf   Int?     @map("installment_of")
  createdAt       DateTime @default(now()) @map("created_at")

  account      Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  importBatch  ImportBatch? @relation(fields: [importBatchId], references: [id])
  recurringMatch RecurringMatch?

  @@map("transactions")
}

model ImportBatch {
  id          String   @id @default(uuid())
  accountId   String   @map("account_id")
  filename    String
  rowCount    Int      @map("row_count")
  importedAt  DateTime @default(now()) @map("imported_at")

  transactions Transaction[]

  @@map("import_batches")
}

// ─── Recurring ────────────────────────────────────────────────────────────────

model RecurringExpense {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  name            String
  expectedAmountShekels Int @map("expected_amount_shekels")
  dayOfMonth      Int?     @map("day_of_month")
  matchPattern    String   @map("match_pattern")
  active          Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  matches RecurringMatch[]

  @@map("recurring_expenses")
}

model RecurringMatch {
  id                 String   @id @default(uuid())
  recurringExpenseId String   @map("recurring_expense_id")
  transactionId      String   @unique @map("transaction_id")
  month              Int
  year               Int
  matchedAt          DateTime @default(now()) @map("matched_at")

  recurringExpense RecurringExpense @relation(fields: [recurringExpenseId], references: [id], onDelete: Cascade)
  transaction      Transaction      @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@map("recurring_matches")
}

// ─── Audit Log ────────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  action     String
  tableName  String   @map("table_name")
  recordId   String   @map("record_id")
  oldValues  Json?    @map("old_values")
  newValues  Json?    @map("new_values")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("audit_log")
}
