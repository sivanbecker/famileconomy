# Database
DATABASE_URL=postgresql://famileconomy:famileconomy@localhost:5432/famileconomy

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-in-production-min-32-chars
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# ─── Observability ────────────────────────────────────────────────────────────

# OpenTelemetry — Grafana Cloud OTLP endpoint
# Sign up: https://grafana.com/products/cloud/ (free tier)
# Endpoint format: https://<zone>.otlp.grafana.net/otlp
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=famileconomy-api
# Grafana Cloud auth header (comma-separated key=value pairs)
# Format: Authorization=Basic <base64(instanceId:apiToken)>
OTEL_EXPORTER_OTLP_HEADERS=

# Better Stack — structured log drain
# Sign up: https://betterstack.com/ (free tier — 1 log destination)
LOGTAIL_SOURCE_TOKEN=

# Sentry — exception tracking
# Sign up: https://sentry.io/ (free tier — 5k errors/month)
SENTRY_DSN=

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Google Drive batch import requires OAuth 2.0 credentials
# Setup guide: docs/GOOGLE_OAUTH_SETUP.md

# Create at: https://console.cloud.google.com/
# 1. Create a new project
# 2. Enable Google Drive API
# 3. Create OAuth 2.0 credentials (Web application)
# 4. Add authorized redirect URI: http://localhost:3001/auth/google/callback

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback
GOOGLE_OAUTH_SUCCESS_REDIRECT=http://localhost:3000/dashboard?googleConnected=true
GOOGLE_OAUTH_FAILURE_REDIRECT=http://localhost:3000/dashboard?googleConnected=false
