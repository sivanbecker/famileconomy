# Database
DATABASE_URL=postgresql://famileconomy:famileconomy@localhost:5432/famileconomy

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-in-production-min-32-chars
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# ─── Observability ────────────────────────────────────────────────────────────

# OpenTelemetry — Grafana Cloud OTLP endpoint
# Sign up: https://grafana.com/products/cloud/ (free tier)
# Endpoint format: https://<zone>.otlp.grafana.net/otlp
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=famileconomy-api
# Grafana Cloud auth header (comma-separated key=value pairs)
# Format: Authorization=Basic <base64(instanceId:apiToken)>
OTEL_EXPORTER_OTLP_HEADERS=

# Better Stack — structured log drain
# Sign up: https://betterstack.com/ (free tier — 1 log destination)
LOGTAIL_SOURCE_TOKEN=

# Sentry — exception tracking
# Sign up: https://sentry.io/ (free tier — 5k errors/month)
SENTRY_DSN=
