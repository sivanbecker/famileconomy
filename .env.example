# Copy this file to .env.local and fill in values — never commit .env.local

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/famileconomy_dev

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_PRIVATE_KEY=      # RS256 private key (PEM format)
JWT_PUBLIC_KEY=       # RS256 public key (PEM format)
JWT_ACCESS_EXPIRES=   # e.g. 15m
JWT_REFRESH_EXPIRES=  # e.g. 30d

# ── Cloudflare R2 ─────────────────────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# ── Observability ─────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=   # Grafana Cloud Tempo endpoint
OTEL_EXPORTER_OTLP_HEADERS=    # Authorization header value
LOGTAIL_SOURCE_TOKEN=           # Better Stack source token
SENTRY_DSN=                     # Sentry project DSN
LOG_LEVEL=info                  # debug | info | warn | error

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
ALLOWED_ORIGINS=http://localhost:3000
